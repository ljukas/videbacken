{
  "name": "oceanview",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "DEV_HOST=$(node scripts/printLanIp.mjs) vite dev --host",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "prepare": "bun run i18n:compile",
    "pretest": "bun run i18n:compile",
    "dev:log": "rm -f /tmp/oceanview-dev.log && vite dev 2>&1 | tee /tmp/oceanview-dev.log",
    "build": "vite build && tsc --noEmit",
    "vercel-build": "drizzle-kit migrate && vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "db:up": "docker compose up -d --wait db",
    "db:down": "docker compose down db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "bunx @better-auth/cli@1.4.21 generate --yes --output src/lib/db/schema/betterAuth.ts && node scripts/patchBetterAuthSchema.mjs",
    "neon:prune": "node scripts/neonPruneBranches.mjs",
    "queue:up": "docker compose up -d --wait queue",
    "queue:down": "docker compose down queue",
    "queue:studio": "docker compose --profile studio up -d queue-studio",
    "storage:up": "docker compose up -d storage storage-init",
    "storage:down": "docker compose down storage storage-init",
    "storage:sync": "node scripts/syncProdStorage.mjs",
    "mail:up": "docker compose up -d --wait mail",
    "mail:down": "docker compose down mail",
    "email:dev": "bunx react-email dev --dir src/emails --port 14601",
    "favicons:generate": "node scripts/generateFavicons.mjs",
    "dev:up": "docker compose up -d --wait db queue mail && docker compose up -d storage storage-init && bun run db:migrate && bun run storage:sync",
    "dev:down": "docker compose down",
    "dev:worker": "tsx scripts/devQueueWorker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:node": "vitest run --project node",
    "test:components": "vitest --project browser",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:ci": "biome check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1082.0",
    "@aws-sdk/s3-request-presigner": "^3.1082.0",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@better-auth/passkey": "^1.6.23",
    "@orpc/client": "^1.14.7",
    "@orpc/experimental-publisher": "^1.14.7",
    "@orpc/server": "^1.14.7",
    "@orpc/tanstack-query": "^1.14.7",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.168.20",
    "@tanstack/react-table": "^8.21.3",
    "@unpic/placeholder": "^0.1.2",
    "@unpic/react": "^1.0.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.6.1",
    "@vercel/functions": "^3.7.5",
    "@vercel/queue": "^0.3.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.23",
    "blurhash": "^2.0.5",
    "bowser": "^2.14.1",
    "bullmq": "^5.79.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "exifreader": "^4.41.0",
    "exponential-backoff": "^3.1.3",
    "heic-convert": "^2.1.0",
    "lucide-react": "^1.23.0",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.8",
    "react-phone-number-input": "^3.4.17",
    "resend": "^6.17.2",
    "shadcn": "^4.13.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unpic": "^4.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@inlang/paraglide-js": "^2.20.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@types/heic-convert": "^2.1.1",
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "nitro": "3.0.260603-beta",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "overrides": {
    "kysely": "^0.28.17"
  },
  "trustedDependencies": [
    "sharp",
    "esbuild",
    "msgpackr-extract",
    "@tailwindcss/oxide",
    "@biomejs/biome"
  ]
}
