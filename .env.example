# Local dev points at a plain Postgres container on localhost (Neon Local is
# PAUSED — see the `db` service in compose.yaml to re-enable; that version
# branches prod and needs `?sslmode=require` appended here again).
# Vercel Preview/Production: DATABASE_URL is auto-provisioned by the Neon Marketplace integration.
DATABASE_URL=postgres://neon:npg@localhost:14520/neondb

# Neon API key + project/branch IDs. Unused while Neon Local is paused locally,
# but kept for CI (ephemeral branches) and to re-enable Neon Local.
# Personal Neon API key (create at https://console.neon.tech/app/settings/api-keys).
NEON_API_KEY=

# Neon project + parent branch IDs (capture once via Neon dashboard or MCP).
# Both are public-ish identifiers; the API key above is the actual secret.
NEON_PROJECT_ID=
PARENT_BRANCH_ID=

# Better Auth — generate via `openssl rand -base64 32`. 32+ chars required.
BETTER_AUTH_SECRET=
# Site origin. Local: http://localhost:14500. Vercel prod: https://oceanview-psi.vercel.app.
BETTER_AUTH_URL=http://localhost:14500

# Comma-separated emails that get auto-promoted to admin role on sign-in.
ADMIN_EMAILS=

# Optional. Logger level: trace | debug | info | warn | error | fatal.
# Defaults to debug in development, info in production.
LOG_LEVEL=

# Vercel Blob — two stores provisioned via Marketplace integration:
#   oceanview-public   (default access: public — user avatars)
#   oceanview-private  (default access: private — sailboat documents)
# Local dev: `vercel env pull` after both stores are connected. Leave blank
# locally to run fully offline against the S3_* block below.
#
# Optionally set these LOCALLY to enable `pnpm storage:sync` (run automatically
# by `pnpm dev:up`), which pulls prod file bytes into local RustFS so prod rows
# surfaced through the Neon branch actually open. Safe: the running app still
# uses the s3 adapter (S3_ENDPOINT wins below) — only the sync script reads
# these. Pull from Vercel production with care.
BLOB_PUBLIC_READ_WRITE_TOKEN=
BLOB_PRIVATE_READ_WRITE_TOKEN=

# Local S3-compatible storage (RustFS in `compose.yaml`). When S3_ENDPOINT is
# set, the storage adapter selects `s3` for local dev (takes precedence over
# BLOB_* tokens). Leave blank in production — Vercel will provision the BLOB_*
# tokens via the Marketplace integration and the `vercelBlob` adapter wins.
# Start the container with `pnpm storage:up` (or `pnpm dev:up`); the
# storage-init sidecar creates both buckets idempotently.
S3_ENDPOINT=http://localhost:14523
S3_REGION=eu-north-1
S3_ACCESS_KEY_ID=oceanview-dev
S3_SECRET_ACCESS_KEY=oceanview-dev-secret-key
S3_BUCKET_PUBLIC=oceanview-public
S3_BUCKET_PRIVATE=oceanview-private

# Optional override. Forces the devLog adapter regardless of the above —
# used by the test harness, useful for offline dev when docker isn't running.
# STORAGE_ADAPTER=devLog

# Local-dev broker for the blurhash queue. When set, queue.publish() routes
# through the bullmqQueue adapter; `pnpm dev:worker` consumes from the same
# URL and runs the shared blurhash handler. Leave blank to keep the no-op
# devLog behaviour (uploads still work; blurhash just isn't generated).
# Start the broker with `pnpm queue:up` (docker compose service `queue`).
REDIS_URL=redis://localhost:14521

# Local SMTP transport — Mailpit (compose.yaml service `mail`, started by
# `pnpm mail:up` or `pnpm dev:up`). When SMTP_HOST is set, the email
# adapter selects `smtp` (takes precedence over RESEND_API_KEY for the
# same reason S3_ENDPOINT wins over BLOB_*: `vercel env pull` doesn't
# accidentally route dev sends through the real Resend account). Inspect
# caught messages at http://localhost:14502.
SMTP_HOST=localhost
SMTP_PORT=14522

# Sender address. Mailpit accepts anything; Resend requires a verified
# domain (see ADR-0008 Deferred work).
EMAIL_FROM=Oceanview <no-reply@oceanview.local>

# Production transport. Selected only when SMTP_HOST is unset. Add this
# to Vercel env once the sender domain is verified.
RESEND_API_KEY=

# Optional override. Forces the devLog adapter regardless of the above.
# Tests also short-circuit via VITEST, so this is only needed for
# explicit offline dev without docker running.
# EMAIL_ADAPTER=devLog

# --- Maps (Recommended Places, ADR-0012) ---
# MapTiler tile API key. CLIENT-EXPOSED BY NATURE: the browser fetches the map
# style JSON, so this is NOT a secret (unlike NEON_API_KEY / BETTER_AUTH_SECRET).
# Restrict it by HTTP-referrer in the MapTiler dashboard. Get one free at
# https://cloud.maptiler.com (Account -> Keys). Vite exposes only VITE_-prefixed
# vars to the client. The map renders blank without it.
VITE_MAPTILER_API_KEY=

